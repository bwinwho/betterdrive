{
  "name": "betterdrive",
  "version": "1.7.3",
  "description": "Your files, rebuilt beautiful.",
  "main": "main.js",
  "author": "Bwin31 / Kode31",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir",
    "prepare": "node scripts/vendor-libs.mjs"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.kode31.betterdrive",
    "productName": "BetterDrive",
    "files": [
      "index.html",
      "standby.html",
      "main.js",
      "preload.js",
      "google-config.js",
      "icons/**/*",
      "preview/**/*",
      "vendor/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "publish": {
      "provider": "github",
      "owner": "bwinwho",
      "repo": "betterdrive",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "pdfjs-dist": "^5.4.624"
  }
}
